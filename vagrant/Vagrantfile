# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Base box configuration
  config.vm.box_check_update = false

  # ========================================================================
  # Splunk Server
  # ========================================================================
  config.vm.define "splunk" do |splunk|
    splunk.vm.box = "ubuntu/jammy64"
    splunk.vm.hostname = "splunk-server"

    splunk.vm.network "private_network", ip: "192.168.56.100"

    splunk.vm.provider "virtualbox" do |vb|
      vb.name = "ssh-bfd-splunk"
      vb.memory = "4096"
      vb.cpus = 2
      vb.linked_clone = true
    end

    splunk.vm.provision "shell", path: "scripts/setup_splunk.sh"
    splunk.vm.provision "shell", path: "scripts/setup_forwarder.sh"
  end

  # ========================================================================
  # Kali Linux Attacker
  # ========================================================================
  config.vm.define "kali" do |kali|
    kali.vm.box = "kalilinux/amd64"
    kali.vm.hostname = "kali-attacker"

    kali.vm.network "private_network", ip: "192.168.56.10"

    kali.vm.provider "virtualbox" do |vb|
      vb.name = "ssh-bfd-kali"
      vb.memory = "2048"
      vb.cpus = 2
      vb.linked_clone = true
      vb.gui = false
    end

    kali.vm.provision "shell", path: "scripts/setup_kali.sh"
  end

  # ========================================================================
  # SSH Target 1 (Ubuntu)
  # ========================================================================
  config.vm.define "target1" do |target|
    target.vm.box = "ubuntu/jammy64"
    target.vm.hostname = "ssh-target-1"

    target.vm.network "private_network", ip: "192.168.56.20"

    target.vm.provider "virtualbox" do |vb|
      vb.name = "ssh-bfd-target-1"
      vb.memory = "1024"
      vb.cpus = 1
      vb.linked_clone = true
    end

    target.vm.provision "shell", path: "scripts/setup_targets.sh"
  end

  # ========================================================================
  # SSH Target 2 (CentOS)
  # ========================================================================
  config.vm.define "target2" do |target|
    target.vm.box = "centos/stream9"
    target.vm.hostname = "ssh-target-2"

    target.vm.network "private_network", ip: "192.168.56.21"

    target.vm.provider "virtualbox" do |vb|
      vb.name = "ssh-bfd-target-2"
      vb.memory = "1024"
      vb.cpus = 1
      vb.linked_clone = true
    end

    target.vm.provision "shell", path: "scripts/setup_targets_centos.sh"
  end

  # ========================================================================
  # SSH Target 3 (Debian)
  # ========================================================================
  config.vm.define "target3" do |target|
    target.vm.box = "debian/bookworm64"
    target.vm.hostname = "ssh-target-3"

    target.vm.network "private_network", ip: "192.168.56.22"

    target.vm.provider "virtualbox" do |vb|
      vb.name = "ssh-bfd-target-3"
      vb.memory = "1024"
      vb.cpus = 1
      vb.linked_clone = true
    end

    target.vm.provision "shell", path: "scripts/setup_targets.sh"
  end

  # Enable SSH agent forwarding for convenience
  config.ssh.forward_agent = true
  config.ssh.insert_key = false
end
